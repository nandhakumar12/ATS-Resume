# --- AWS Connectivity ---
aws_region = "us-east-1"

# --- Identification ---
student_id = "25126067"
key_name   = "your-aws-key-pair-name"

# --- Networking (Find these in your AWS Console) ---
vpc_id            = "vpc-xxxxxxxxxxxxxxxxx"
public_subnet_ids = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-yyyyyyyyyyyyyyyyy"]

# --- Domain & AI ---
domain_name    = "nandhakumar.works"
gemini_api_key = "your-google-gemini-api-key-here"

# --- Cognito & Auth ---
# Manually create these in the new account first
cognito_user_pool_id = "us-east-1_xxxxxxxxx"
cognito_client_id    = "xxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- IAM ---
# Use "LabInstanceProfile" for AWS Academy Labs, or your own role for standard accounts
iam_instance_profile = "LabInstanceProfile"
